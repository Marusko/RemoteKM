<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary action button -->
    <Style x:Key="RkPrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource RkAccent}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- Secondary / outline button -->
    <Style x:Key="RkGhostButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource RkSurfaceAlt}" />
        <Setter Property="TextColor" Value="{StaticResource RkText}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- Danger button -->
    <Style x:Key="RkDangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource RkDanger}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- On-screen keyboard key -->
    <Style x:Key="RkKey" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource RkKeyBg}" />
        <Setter Property="TextColor" Value="{StaticResource RkText}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="MinimumWidthRequest" Value="0" />
        <Setter Property="HeightRequest" Value="46" />
    </Style>

    <!-- Modifier key (Ctrl/Alt/Shift/Win) -->
    <Style x:Key="RkModKey" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource RkSurfaceAlt}" />
        <Setter Property="TextColor" Value="{StaticResource RkMuted}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="HeightRequest" Value="46" />
    </Style>

    <!-- Left navigation rail button -->
    <Style x:Key="RkNavButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource RkMuted}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Left navigation rail tile (icon set in code-behind) -->
    <Style x:Key="RkNavTile" TargetType="Border">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- Card / surface container -->
    <Style x:Key="RkCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource RkSurface}" />
        <Setter Property="Stroke" Value="{StaticResource RkStroke}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Padding" Value="16" />
    </Style>

</ResourceDictionary>
