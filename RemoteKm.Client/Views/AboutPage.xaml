<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RemoteKm.Client.Views.AboutPage"
             Title="About &amp; licenses"
             BackgroundColor="{StaticResource RkBg}">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="14">
            <Label Text="RemoteKm" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource RkText}" />
            <Border Style="{StaticResource RkCard}">
                <Label x:Name="LicenseText" FontSize="14" TextColor="{StaticResource RkText}" LineHeight="1.35" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
