<Window x:Class="RemoteKm.Host.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteKM — About &amp; licenses"
        Width="500" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI"
        Background="{StaticResource RkBgBrush}"
        Icon="/icon.ico">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <Ellipse Width="12" Height="12" Fill="{StaticResource RkAccentBrush}" VerticalAlignment="Center" />
            <TextBlock Text="About &amp; licenses" Style="{StaticResource RkTitle}" Margin="10,0,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource RkSurfaceBrush}" CornerRadius="12"
                BorderBrush="{StaticResource RkStrokeBrush}" BorderThickness="1" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LicenseText" Foreground="{StaticResource RkTextBrush}"
                           FontSize="13" TextWrapping="Wrap" LineHeight="20" />
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2" Content="Close" Width="110" HorizontalAlignment="Right" Margin="0,14,0,0"
                Style="{StaticResource RkButton}" Click="OnClose" />
    </Grid>
</Window>
