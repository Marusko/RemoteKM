<Window x:Class="RemoteKm.Host.Windows.QrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteKM — Connect via QR"
        Width="340" Height="410"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI"
        Background="{StaticResource RkBgBrush}"
        Icon="/icon.ico">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
            <Ellipse Width="12" Height="12" Fill="{StaticResource RkAccentBrush}" VerticalAlignment="Center" />
            <TextBlock Text="Scan to connect" Style="{StaticResource RkTitle}" Margin="10,0,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="12"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image x:Name="QrImage" Width="240" Height="240" Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
        </Border>

        <TextBlock Grid.Row="2" x:Name="UriText" Style="{StaticResource RkCaption}" FontSize="13"
                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,14,0,0" />
    </Grid>
</Window>
