<Window x:Class="RemoteKm.Host.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteKM — Settings"
        Width="440" Height="590"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI"
        Background="{StaticResource RkBgBrush}"
        Icon="/icon.ico">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12" Fill="{StaticResource RkAccentBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Settings" Style="{StaticResource RkTitle}" Margin="10,0,0,0" />
            </StackPanel>
            <Border Background="{StaticResource RkSurfaceBrush}" CornerRadius="10" Padding="12,8" Margin="0,12,0,0">
                <TextBlock x:Name="ListeningText" Style="{StaticResource RkCaption}" />
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Control port (1024–65535)" Style="{StaticResource RkCaption}" Margin="0,0,0,6" />
            <TextBox x:Name="PortBox" Style="{StaticResource RkTextBox}" />
            <TextBlock x:Name="PortError" Foreground="{StaticResource RkDangerBrush}" FontSize="12"
                       Visibility="Collapsed" Margin="0,6,0,0" />
        </StackPanel>

        <CheckBox Grid.Row="2" x:Name="AutoStartCheck" Content="Auto-start with Windows"
                  Style="{StaticResource RkCheckBox}" Margin="0,0,0,16" />

        <CheckBox Grid.Row="3" x:Name="RequireConfirmCheck" Content="Require confirmation for new clients"
                  Style="{StaticResource RkCheckBox}" Margin="0,0,0,14" />

        <CheckBox Grid.Row="4" x:Name="ReverseScrollCheck" Content="Reverse scroll direction"
                  Style="{StaticResource RkCheckBox}" Margin="0,0,0,18" />

        <StackPanel Grid.Row="5">
            <TextBlock Text="Logs &amp; data" Style="{StaticResource RkCaption}" Margin="0,0,0,8" />
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Open logs folder" Height="40" Style="{StaticResource RkButton}"
                        Margin="0,0,5,0" Click="OnOpenLogs" />
                <Button Grid.Column="1" Content="About &amp; licenses" Height="40" Style="{StaticResource RkButton}"
                        Margin="5,0,0,0" Click="OnAbout" />
            </Grid>
            <Button Content="Remove all data &amp; settings…" Height="40" Style="{StaticResource RkDangerButton}"
                    Click="OnRemoveAllData" />
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="100" Style="{StaticResource RkButton}"
                    Margin="0,0,10,0" Click="OnCancel" />
            <Button Content="Save" Width="100" Style="{StaticResource RkAccentButton}" Click="OnSave" />
        </StackPanel>
    </Grid>
</Window>
