<Window x:Class="RemoteKm.Host.Windows.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteKM"
        Width="440" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI"
        Background="{StaticResource RkBgBrush}"
        Icon="/icon.ico">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Ellipse Width="12" Height="12" Fill="{StaticResource RkDangerBrush}" VerticalAlignment="Center" />
            <TextBlock x:Name="TitleText" Style="{StaticResource RkTitle}" Margin="10,0,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="MessageText" Foreground="{StaticResource RkTextBrush}"
                   FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel" Height="44" Style="{StaticResource RkButton}" Click="OnCancel" />
            <Button Grid.Column="2" x:Name="ConfirmButton" Content="Confirm" Height="44"
                    Style="{StaticResource RkDangerButton}" Click="OnConfirm" />
        </Grid>
    </Grid>
</Window>
