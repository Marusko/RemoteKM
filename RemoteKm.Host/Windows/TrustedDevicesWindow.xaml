<Window x:Class="RemoteKm.Host.Windows.TrustedDevicesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteKM — Trusted devices"
        Width="600" Height="440"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI"
        Background="{StaticResource RkBgBrush}"
        Icon="/icon.ico">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Ellipse Width="12" Height="12" Fill="{StaticResource RkAccentBrush}" VerticalAlignment="Center" />
            <TextBlock Text="Trusted devices" Style="{StaticResource RkTitle}" Margin="10,0,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyText" Text="No trusted devices yet." Style="{StaticResource RkCaption}"
                       VerticalAlignment="Top" Visibility="Collapsed" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="List">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource RkSurfaceBrush}" CornerRadius="12"
                                    BorderBrush="{StaticResource RkStrokeBrush}" BorderThickness="1"
                                    Padding="14" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource RkTextBrush}"
                                                   FontSize="15" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Subtitle}" Style="{StaticResource RkCaption}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Revoke trust" Width="120"
                                            Style="{StaticResource RkDangerButton}" Click="OnRevoke" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
